# 宿主 TLS 边缘 Nginx 模板(与容器栈配套;生产实例:/etc/nginx/sites-available/dorami-docker,
# 域名 www.dorami.cloud)。职责只有一件:443 终止 TLS 后全站反代到容器栈
# (DORAMI_HTTP_LISTEN=127.0.0.1:8080,见项目根 .env)。静态资产/API 反代/安全响应头
# 均由容器内 nginx 承担,宿主只补 HSTS。
#
# 用法:替换 your.domain.com 与证书路径 → 放入 sites-available → ln -s 到 sites-enabled
#       → nginx -t && nginx -s reload。证书更换/续期不动容器栈。
map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80 default_server;
    server_name your.domain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl default_server;
    server_name your.domain.com;

    ssl_certificate /etc/nginx/ssl/your.domain.com.pem;
    ssl_certificate_key /etc/nginx/ssl/your.domain.com.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=15552000" always;

    client_max_body_size 100m;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_pass http://127.0.0.1:8080;
    }
}
